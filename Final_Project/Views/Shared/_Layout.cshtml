@using Microsoft.AspNetCore.Identity
@inject SignInManager<Final_Project.Areas.Identity.Data.ApplicationUser> SignInManager
@inject UserManager<Final_Project.Areas.Identity.Data.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AI Tutor</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Final_Project.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        /* Subtle polish for the links */
        .nav-link {
            transition: color 0.2s ease-in-out;
        }

            .nav-link:hover {
                color: #0d6efd !important;
            }

        /* Standardizes the look of the login partial buttons/links */
        .navbar-identity .nav-link {
            font-weight: 600;
        }

        /* Tracking for the logo */
        .tracking-tight {
            letter-spacing: -0.5px;
            font-size: 1.25rem;
        }

        /* Ensure sticky-top plays nice with glassmorphism */
        .sticky-top {
            backdrop-filter: blur(10px);
            background-color: rgba(255, 255, 255, 0.95) !important;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm py-3 mb-5 sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="bg-primary text-white p-1 rounded me-2">
                        <i class="bi bi-cpu-fill" style="font-size: 1.2rem;"></i>
                    </span>
                    <span class="tracking-tight text-dark">AI TUTOR</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold text-secondary px-3" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold text-secondary px-3" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>

                        @if (SignInManager.IsSignedIn(User)
                                                && !User.IsInRole("Professor")
                                                && !User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold text-secondary px-3" asp-area="" asp-controller="Users" asp-action="Index">
                                    <i class="bi bi-people-fill me-1"></i> Manage Users
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center navbar-identity">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Final_Project - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
