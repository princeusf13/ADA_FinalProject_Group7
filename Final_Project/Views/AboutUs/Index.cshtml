@{
    ViewData["Title"] = "Meet the Team";
}

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <span class="badge bg-primary-soft rounded-pill px-3 py-2 mb-2">OUR CONTRIBUTORS</span>
        <h1 class="display-5 fw-bold text-dark">The Minds Behind <span class="text-primary">StudySense AI</span></h1>
        <p class="text-muted mx-auto mb-4" style="max-width: 600px;">
            A collaborative effort from the members of group 7 from App Dev Analytics, Muma College of Business, integrating advanced .NET 10 development with modern web architectures.
        </p>

        <a href="https://github.com/princeusf13/ADA_FinalProject_Group7" target="_blank" class="btn btn-dark rounded-pill px-4 py-2 shadow-sm github-btn">
            <i class="bi bi-github me-2"></i> View Project on GitHub
        </a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-lg-3 col-md-6">
            <div class="glass-card h-100 p-0 overflow-hidden shadow-sm team-card border-0">
                <div class="member-photo-wrapper">
                    <img src="~/images/prince.jpeg" alt="Prince Praveen" onerror="this.src='https://via.placeholder.com/300x300?text=Prince+Praveen'" class="member-photo">
                </div>
                <div class="p-4">
                    <h5 class="fw-bold mb-1">Prince Praveen</h5>
                    <p class="text-primary small fw-bold mb-3">Role: Developer</p>
                    <div class="contribution-list small text-muted">
                        <div class="mb-3">
                            <div class="fw-bold text-dark"><i class="bi bi-cpu-fill me-2 text-primary"></i>AI Core Logic</div>
                            Architected contextual engine and state management.
                        </div>
                        <div class="mb-3">
                            <div class="fw-bold text-dark"><i class="bi bi-shield-lock-fill me-2 text-primary"></i>Security</div>
                            Implemented ASP.NET Identity and RBAC (Admin/Student).
                        </div>
                        <div>
                            <div class="fw-bold text-dark"><i class="bi bi-cloud-check-fill me-2 text-primary"></i>Infrastructure</div>
                            Managed Azure deployment and GitHub Actions CI/CD.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="glass-card h-100 p-0 overflow-hidden shadow-sm team-card border-0">
                <div class="member-photo-wrapper">
                    <img src="~/images/sushma.jpeg" alt="Sushma Swaraj Padala" onerror="this.src='https://via.placeholder.com/300x300?text=Sushma+Swaraj'" class="member-photo">
                </div>
                <div class="p-4">
                    <h5 class="fw-bold mb-1">Sushma Swaraj Padala</h5>
                    <p class="text-primary small fw-bold mb-3">Role: Developer</p>
                    <div class="contribution-list small text-muted">
                        <div class="mb-3">
                            <div class="fw-bold text-dark"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Analytics</div>
                            Built LINQ aggregations and Chart.js dashboards.
                        </div>
                        <div class="mb-3">
                            <div class="fw-bold text-dark"><i class="bi bi-layout-text-window me-2 text-primary"></i>Curriculum</div>
                            Developed Full-Stack CRUD for Courses and Topics.
                        </div>
                        <div>
                            <div class="fw-bold text-dark"><i class="bi bi-database-fill-gear me-2 text-primary"></i>Database</div>
                            Led EF Core migrations and relational schema design.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="glass-card h-100 p-0 overflow-hidden shadow-sm team-card border-0">
                <div class="member-photo-wrapper">
                    <img src="~/images/harshitha.jpg" alt="Harshitha Neerudu" onerror="this.src='https://via.placeholder.com/300x300?text=Harshitha+N'" class="member-photo">
                </div>
                <div class="p-4">
                    <h5 class="fw-bold mb-1">Harshitha Neerudu</h5>
                    <p class="text-primary small fw-bold mb-3">Role: Developer</p>
                    <div class="contribution-list small text-muted">
                        <div class="mb-3">
                            <div class="fw-bold text-dark"><i class="bi bi-controller me-2 text-primary"></i>Trivia Integration</div>
                            Managed API consumption and randomization logic.
                        </div>
                        <div class="mb-3">
                            <div class="fw-bold text-dark"><i class="bi bi-palette-fill me-2 text-primary"></i>UI Architecture</div>
                            Designed the Glassmorphism system and CSS filters.
                        </div>
                        <div>
                            <div class="fw-bold text-dark"><i class="bi bi-check-all me-2 text-primary"></i>Form Validation</div>
                            Created client/server-side validation frameworks.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="glass-card h-100 p-0 overflow-hidden shadow-sm team-card border-0">
                <div class="member-photo-wrapper">
                    <img src="~/images/koushik.jpg" alt="Koushik Devalapalli" onerror="this.src='https://via.placeholder.com/300x300?text=Koushik+D'" class="member-photo">
                </div>
                <div class="p-4">
                    <h5 class="fw-bold mb-1">Koushik Devalapalli</h5>
                    <p class="text-primary small fw-bold mb-3">Role: Developer</p>
                    <div class="contribution-list small text-muted">
                        <div class="mb-3">
                            <div class="fw-bold text-dark"><i class="bi bi-magic me-2 text-primary"></i>Onboarding Wizard</div>
                            Engineered the AJAX multi-step flow using jQuery.
                        </div>
                        <div class="mb-3">
                            <div class="fw-bold text-dark"><i class="bi bi-activity me-2 text-primary"></i>User Tracking</div>
                            Built the AI Interaction behavioral logging system.
                        </div>
                        <div>
                            <div class="fw-bold text-dark"><i class="bi bi-shield-shaded me-2 text-primary"></i>System Safety</div>
                            Implemented input sanitization and error middleware.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="glass-card p-4 rounded-4 shadow-sm border-0">
                <button class="btn btn-link w-100 d-flex justify-content-between align-items-center text-decoration-none py-2" type="button" data-bs-toggle="collapse" data-bs-target="#techDetails">
                    <h4 class="fw-bold text-dark mb-0"><i class="bi bi-gear-wide-connected text-primary me-2"></i> Project Technical Architecture</h4>
                    <i class="bi bi-chevron-down fs-4 text-primary"></i>
                </button>

                <div class="collapse" id="techDetails">
                    <div class="pt-4 px-2 border-top mt-3">
                        <div class="row">
                            <div class="col-md-6 mb-4 border-end">
                                <h5 class="fw-bold text-primary mb-3">Implementation Details</h5>
                                <p class="small text-muted">
                                    The AI Tutor platform is an N-Tier ASP.NET Core application utilizing <strong>Entity Framework Core</strong> for data persistence and <strong>Azure</strong> for cloud scale.
                                </p>
                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    <span class="badge bg-light text-dark border">.NET 10</span>
                                    <span class="badge bg-light text-dark border">C#</span>
                                    <span class="badge bg-light text-dark border">EF Core</span>
                                    <span class="badge bg-light text-dark border">Azure SQL</span>
                                    <span class="badge bg-light text-dark border">Bootstrap 5</span>
                                    <span class="badge bg-light text-dark border">Chart.js</span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <h5 class="fw-bold text-primary mb-3">Entity Relationship Diagram</h5>
                                <div class="erd-wrapper rounded-3 border overflow-hidden bg-white shadow-sm cursor-pointer" data-bs-toggle="modal" data-bs-target="#erdModal">
                                    <img src="~/images/erd.png" class="img-fluid w-100" alt="ERD Preview" style="opacity: 0.9;">
                                    <div class="text-center p-2 bg-light">
                                        <span class="small text-muted fw-bold"><i class="bi bi-zoom-in me-1"></i> View Full Schema</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="erdModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content glass-card border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Database Schema & Entity Relationships</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <img src="~/images/erd.png" class="img-fluid w-100" alt="Full ERD">
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
    }

    .team-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 20px !important;
    }

        .team-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .member-photo-wrapper {
        height: 250px;
        overflow: hidden;
        background: #f8f9fa;
    }

    .member-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .team-card:hover .member-photo {
        transform: scale(1.1);
    }

    .bg-primary-soft {
        background-color: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .github-btn {
        transition: all 0.3s ease;
        border: none;
    }

        .github-btn:hover {
            background-color: #333;
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

    .erd-wrapper {
        transition: all 0.3s ease;
    }

        .erd-wrapper:hover {
            border-color: #0d6efd !important;
            transform: scale(1.02);
        }

    ul li {
        display: flex;
        align-items: flex-start;
        line-height: 1.4;
    }

    [aria-expanded="true"] .bi-chevron-down {
        transform: rotate(180deg);
        transition: transform 0.3s ease;
    }
</style>