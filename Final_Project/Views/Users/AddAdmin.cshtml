<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-card p-5 rounded-4 shadow-lg border-0">
                <h2 class="fw-bold mb-4 text-center">Create Admin Account</h2>

                <form asp-action="AddAdmin" method="post">
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <div class="form-floating shadow-sm">
                                <input name="firstName" class="form-control border-0" placeholder="First Name" required />
                                <label>First Name</label>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="form-floating shadow-sm">
                                <input name="lastName" class="form-control border-0" placeholder="Last Name" required />
                                <label>Last Name</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3 shadow-sm">
                        <input name="email" type="email" class="form-control border-0" placeholder="name@example.com" required />
                        <label>Email Address</label>
                    </div>

                    <div class="form-floating mb-4 shadow-sm">
                        <input name="password" type="password" class="form-control border-0" placeholder="Password" required />
                        <label>Password</label>
                    </div>

                    <button type="submit" class="btn btn-dark btn-lg rounded-pill w-100 py-3 shadow">
                        <i class="bi bi-shield-lock-fill me-2"></i> Register New Admin
                    </button>

                    <div class="text-center mt-3">
                        <a asp-action="Index" class="btn btn-link text-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>