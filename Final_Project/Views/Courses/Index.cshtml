@model IEnumerable<Final_Project.Models.Course>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Active Courses</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg"></i> Create New Course
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="glass-card p-4 rounded-4 shadow-sm h-100">
                    <h4 class="fw-bold text-primary">@item.Name</h4>
                    <p class="text-muted">@item.Description</p>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-secondary">Created: @item.CreatedAt.ToShortDateString()</small>
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.CourseID" class="btn btn-sm btn-outline-warning border-0"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.CourseID" class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-trash"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>