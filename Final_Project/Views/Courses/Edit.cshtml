@model Final_Project.Models.Course

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="glass-card p-5 rounded-4 shadow">
                <h2 class="fw-bold mb-4">Edit Course</h2>
                <form asp-action="Edit">
                    <input type="hidden" asp-for="CourseID" />
                    <input type="hidden" asp-for="CreatedAt" /> @* Keep the original creation date *@

                    <div class="form-floating mb-3">
                        <input asp-for="Name" class="form-control" placeholder="Course Name" />
                        <label asp-for="Name">Course Title</label>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <textarea asp-for="Description" class="form-control" style="height: 100px" placeholder="Description"></textarea>
                        <label asp-for="Description">Course Description</label>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning btn-lg rounded-pill fw-bold">Update Course</button>
                        <a asp-action="Index" class="btn btn-link text-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>