@model IEnumerable<Final_Project.Models.CourseTopic>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Course Topics</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg"></i> Add New Topic
        </a>
    </div>

    <div class="glass-card p-4 rounded-4 shadow-sm">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Topic Name</th>
                    <th>Parent Course</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-dark">@item.Name</td>
                        <td>
                            <span class="badge bg-info text-dark rounded-pill px-3">
                                @item.Course.Name
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.TopicID" class="btn btn-sm btn-outline-warning border-0"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.TopicID" class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>